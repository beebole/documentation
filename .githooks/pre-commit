#!/bin/bash
#
# Pre-commit hook: auto-convert staged PNG/JPG images to WebP,
# rename them for SEO based on the .mdx page that references them,
# and update all .mdx references automatically.
#
# Naming logic:
#   - Finds the .mdx file referencing the image
#   - Uses the page slug as a prefix: timesheets.mdx → "timesheets-"
#   - Cleans the original filename to kebab-case
#   - Skips prefixing if the filename already starts with the page slug
#   - If no .mdx references the image, just cleans the name to kebab-case
#
# Example: screenshot 2.PNG referenced in timesheets.mdx
#          → timesheets-screenshot-2.webp
#
# Requires: cwebp (brew install webp)
#

QUALITY=80

# Check if cwebp is available
if ! command -v cwebp &>/dev/null; then
  echo "⚠️  cwebp not found. Install it with: brew install webp"
  echo "   Skipping image optimization."
  exit 0
fi

# Find staged PNG and JPG files in help/images/
STAGED_IMAGES=$(git diff --cached --name-only --diff-filter=ACM | grep -iE '\.(png|jpe?g)$' | grep '^help/images/')

if [ -z "$STAGED_IMAGES" ]; then
  exit 0
fi

# Convert a string to clean kebab-case:
#   "Screenshot 2 (Final).png" → "screenshot-2-final"
to_kebab() {
  echo "$1" \
    | sed 's/\.[^.]*$//' \
    | tr '[:upper:]' '[:lower:]' \
    | sed 's/[^a-z0-9]/-/g' \
    | sed 's/--*/-/g' \
    | sed 's/^-//' \
    | sed 's/-$//'
}

echo "🖼  Optimizing images to WebP..."

for img in $STAGED_IMAGES; do
  # Skip if file no longer exists
  [ -f "$img" ] || continue

  # Get the directory the image is in (e.g., help/images/ or help/images/fr/)
  img_dir=$(dirname "$img")
  img_basename=$(basename "$img")
  old_ref="/images/$(basename "$img")"

  # Clean the original filename to kebab-case (without extension)
  clean_name=$(to_kebab "$img_basename")

  # Find the .mdx file that references this image
  page_slug=""
  mdx_match=$(grep -rl "$old_ref" help/ --include='*.mdx' 2>/dev/null | head -1)

  if [ -n "$mdx_match" ]; then
    # Extract the page slug from the .mdx path
    # e.g., help/documentation/timesheets.mdx → timesheets
    # e.g., help/fr/documentation/timesheets.mdx → timesheets
    page_slug=$(basename "$mdx_match" .mdx)
  fi

  # Build the new filename
  if [ -n "$page_slug" ]; then
    # Check if the clean name already starts with the page slug
    if echo "$clean_name" | grep -q "^${page_slug}"; then
      new_name="${clean_name}.webp"
    else
      new_name="${page_slug}-${clean_name}.webp"
    fi
  else
    # No .mdx reference found — just use the cleaned name
    new_name="${clean_name}.webp"
  fi

  webp_path="${img_dir}/${new_name}"

  # Convert to WebP
  if cwebp -q "$QUALITY" "$img" -o "$webp_path" -quiet; then
    # Get file sizes for reporting
    orig_size=$(wc -c < "$img" | tr -d ' ')
    webp_size=$(wc -c < "$webp_path" | tr -d ' ')
    savings=$(( (orig_size - webp_size) * 100 / orig_size ))

    echo "   ✅ $(basename "$img") → ${new_name} (${savings}% smaller)"

    # Build the new reference path (relative to help/)
    # For help/images/foo.webp → /images/foo.webp
    # For help/images/fr/foo.webp → /images/fr/foo.webp
    new_ref="/images/${webp_path#help/images/}"

    # Update all .mdx files that reference the old image
    mdx_files=$(grep -rl "$old_ref" help/ --include='*.mdx' 2>/dev/null)
    if [ -n "$mdx_files" ]; then
      for mdx in $mdx_files; do
        sed -i '' "s|${old_ref}|${new_ref}|g" "$mdx"
        git add "$mdx"
        echo "   📝 Updated reference in $(basename "$mdx")"
      done
    fi

    # Stage the new WebP file and remove the original
    git add "$webp_path"
    git rm --cached "$img" -q 2>/dev/null
    rm "$img"
  else
    echo "   ❌ Failed to convert $(basename "$img") — committing original"
  fi
done
